# macOS
.DS_Store
Icon?

# Secrets
.env

# === DATA (large, regenerable — back up via sync_local.sh, NOT git) ===
# Use /* (not /) so that file-level !exceptions below still work
data/*
logs/
checkpoints/
results/

# Keep placeholder markers for empty tracked dirs
!data/.gitkeep
!logs/.gitkeep
!checkpoints/.gitkeep
!results/.gitkeep
!data/personas/.gitkeep
!data/dialogue/.gitkeep
!data/memories/.gitkeep
!data/eval_probes/.gitkeep

# review_package.json is too large for git — regenerate with scripts/make_review_package.py
data/review_package.json

# v2 benchmark results are small CSVs — track them in git
!v2_temporal_benchmark/results/
!v2_temporal_benchmark/results/*.csv

# Scratchpad
Scratchpad/

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/
*.egg

# Secrets
.env

# === DATA (large, regenerable — back up via sync_local.sh, NOT git) ===
# Use /* (not /) so that file-level !exceptions below still work
data/*
logs/
checkpoints/
results/

# Keep placeholder markers for empty tracked dirs
!data/.gitkeep
!logs/.gitkeep
!checkpoints/.gitkeep
!results/.gitkeep
!data/personas/.gitkeep
!data/dialogue/.gitkeep
!data/memories/.gitkeep
!data/eval_probes/.gitkeep

# Review package lives in git so reviewers can access it directly
!data/review_package.json


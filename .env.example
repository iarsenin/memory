# Copy this to .env and fill in values. Never commit .env to git.

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
TIMEZONE=America/New_York

# HuggingFace token — required for Phase 5+ (Llama-3-8B-Instruct download).
# Accept the Llama-3 license first: https://huggingface.co/meta-llama/Meta-Llama-3-8B-Instruct
HUGGING_FACE_TOKEN=hf_...

# Optional — only needed if using Gmail notifications
GMAIL_USER=
GMAIL_APP_PASSWORD=
EMAIL_TO=
EMAIL_FROM=
